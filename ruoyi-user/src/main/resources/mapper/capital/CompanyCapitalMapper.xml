<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.capital.mapper.CompanyCapitalMapper">
    
    <resultMap type="CompanyCapital" id="CompanyCapitalResult">
        <result property="id"    column="id"    />
        <result property="serviceType"    column="service_type"    />
        <result property="companyId"    column="company_id"    />
        <result property="availableAmount"    column="available_amount"    />
        <result property="frozenAmount"    column="frozen_amount"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="withdrawingAmount"    column="withdrawing_amount"    />
    </resultMap>


    <update id="updateAvailableAmount">
        UPDATE u_company_capital
        SET available_amount = IFNULL(available_amount, 0) + #{amount}
        WHERE id = #{id}
        and IFNULL(available_amount, 0) + #{amount} >= 0
    </update>

    <update id="updateFrozenAmount">
        UPDATE u_company_capital
        SET frozen_amount = IFNULL(frozen_amount, 0) + #{amount} , available_amount = IFNULL(available_amount, 0) + #{amount}
        WHERE id = #{id}
        and IFNULL(available_amount, 0) + #{amount} >= 0
    </update>

</mapper>