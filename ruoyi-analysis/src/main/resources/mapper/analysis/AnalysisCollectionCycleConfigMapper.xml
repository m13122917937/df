<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.analysis.mapper.AnalysisCollectionCycleConfigMapper">
    <select id="selectByPlatformAndShop" resultType="com.ruoyi.analysis.domain.AnalysisCollectionCycleConfig">
        select * from ana_collection_cycle_config where platform = #{platform} and shop_name = #{shopName} limit 1
    </select>
</mapper>
